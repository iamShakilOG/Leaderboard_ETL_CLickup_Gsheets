# Safe to commit. Copy this file to .env for local use.
# Do not commit the real .env with secrets.

CLICKUP_API_TOKEN=replace_with_real_token
CLICKUP_LIST_ID=replace_with_clickup_list_id
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json
DELIVERY_SHEET_KEY=replace_with_google_sheet_key
DELIVERY_WORKSHEET=charter_stats
RATING_WORKSHEET=rating_and_contribution
FINAL_REPORT_WORKSHEET=final_report
ETL_LOGS_WORKSHEET=ETL_Logs
START_DATE=2025-06-01
END_DATE=
YEAR_FILTER=2025
PAGE_SIZE=100
TIME_ZONE_OFFSET=6
LOG_LEVEL=INFO
SCHEDULE_EVERY_DAYS=3
SCHEDULE_GUARD_ENABLED=false
FORCE_RUN=false
CLICKUP_TIMEOUT_SECONDS=60
GOOGLE_RETRY_SLEEP_SECONDS=1.0
CLICKUP_MIN_INTERVAL_SECONDS=0.8
GSHEET_MIN_INTERVAL_SECONDS=1.2
GSHEET_WRITE_CHUNK_SIZE=500
API_MAX_RETRIES=8
